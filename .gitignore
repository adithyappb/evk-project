# --- Python ---
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/

# --- Virtualenvs / build artifacts ---
.venv/
dist/
build/

# --- Tooling caches ---
.mypy_cache/
.ruff_cache/
.pytest_cache/

# --- Editors / OS ---
.DS_Store
.idea/
.vscode/

# --- Secrets & local state (NEVER commit) ---
# Block every local env file variant, then whitelist the shareable example.
# `.env.example` is the committed template; `.env` must stay local.
.env
.env.*
!.env.example
credentials.txt
secrets/
*.pem
*.key
service-account*.json

# --- Runtime data (local-mode JSON store + send logs) ---
data/

# --- Backup copies (macOS Finder duplicates) ---
*\ copy/
*\ copy.*
.claude/worktrees/
