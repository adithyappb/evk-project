# =============================================================================
# EVK — .env.example  (PRE-PRODUCTION / LOCAL DEV TEMPLATE ONLY)
#
# This file is safe to commit. It ships with stub-only placeholders so the app
# boots with ZERO real credentials. Copy it to `.env` — which IS gitignored —
# and edit that copy:
#
#   cp    .env.example .env    (macOS / Linux)
#   copy  .env.example .env    (Windows PowerShell / cmd)
#
# WARNING — never ship this file (or `.env`) into a production runtime.
#   * In production, inject real secrets via your platform (Cloud Run env vars,
#     Secret Manager, k8s Secrets, GitHub Actions secrets, etc.).
#   * Do NOT bake real API keys, signing keys, or service-account JSON into
#     container images or repos — `.gitignore` already blocks `.env*`,
#     `secrets/`, `*.pem`, `*.key`, and `service-account*.json`.
#   * Rotate PRIVACY_SALT + ADMIN_API_TOKEN before first production deploy.
#
# The defaults below run EVK entirely locally: file-backed store, stubbed
# Inkbox, pattern-matching Gemini. To use real services, flip EVK_MODE to
# `production` and fill in the sections marked (REQUIRED FOR PRODUCTION).
# =============================================================================

# -----------------------------------------------------------------------------
# Mode
# -----------------------------------------------------------------------------
# local       — stubs + local JSON store, no real API calls (DEFAULT)
# production  — real Inkbox + Firestore + Vertex AI Gemini
EVK_MODE=local

# Local-mode data directory (created on first write; gitignored).
LOCAL_DATA_DIR=./data

# -----------------------------------------------------------------------------
# Inkbox  (REQUIRED FOR PRODUCTION)
# -----------------------------------------------------------------------------
# Any `ApiKey_local...` or `ApiKey_test...` value is treated as a stub.
# Get real keys at https://inkbox.ai/.
INKBOX_API_KEY=ApiKey_local_stub
INKBOX_AGENT_HANDLE=evk-agent
INKBOX_SIGNING_KEY=whsec_local_stub_signing_key_change_me
INKBOX_WEBHOOK_TOLERANCE_SECONDS=300

# -----------------------------------------------------------------------------
# Gemini
# -----------------------------------------------------------------------------
# Option A (free + easy): set GOOGLE_API_KEY from https://aistudio.google.com/apikey
# Option B (production):  leave GOOGLE_API_KEY empty and set the Vertex vars below.
# Option C (zero-config): leave GOOGLE_API_KEY empty *and* stay in local mode —
#                         the stub classifier will take over.
GOOGLE_API_KEY=

# (REQUIRED FOR PRODUCTION — ignored in local mode without GOOGLE_API_KEY)
GOOGLE_CLOUD_PROJECT=evk-local
GOOGLE_CLOUD_LOCATION=us-central1
GEMINI_MODEL=gemini-2.5-flash

# -----------------------------------------------------------------------------
# Firestore  (REQUIRED FOR PRODUCTION)
# -----------------------------------------------------------------------------
# In local mode these are ignored. Run `gcloud auth application-default login`
# before starting the server in production mode.
# FIRESTORE_PROJECT=
FIRESTORE_DATABASE=(default)

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8080
APP_LOG_LEVEL=INFO
REQUIRE_APPROVAL=true
ADMIN_BASE_URL=http://localhost:8080
ADMIN_EMAIL=admin@example.com

# Comma-separated list of days-before-deadline at which to send reminders.
REMINDER_DAYS_BEFORE=7,2

# -----------------------------------------------------------------------------
# Login / verification
# -----------------------------------------------------------------------------
# Local development:
# - sample accounts live in credentials.txt
# - verification codes print in the local server terminal
# Production:
# - switch AUTH_EMAIL_DELIVERY_MODE to smtp
# - provide your real SMTP settings below
SESSION_COOKIE_NAME=evk_session
SESSION_TTL_HOURS=12
LOGIN_CODE_TTL_MINUTES=10
AUTH_LOCAL_DEMO_PASSWORD=ChangeMe123!
AUTH_EMAIL_DELIVERY_MODE=terminal
AUTH_SMTP_HOST=localhost
AUTH_SMTP_PORT=1025
AUTH_SMTP_USERNAME=
AUTH_SMTP_PASSWORD=
AUTH_SMTP_SENDER=login@evkids.local

# -----------------------------------------------------------------------------
# Admin API auth (optional bearer token; empty = no auth, dev default)
# -----------------------------------------------------------------------------
# When set, every /admin/* endpoint requires `Authorization: Bearer <token>`.
# In production, also front this behind Cloud Run IAM / IAP.
# ADMIN_API_TOKEN=

# -----------------------------------------------------------------------------
# Privacy / pseudonymisation
# -----------------------------------------------------------------------------
# Salt used to hash student IDs before they're sent to Gemini. Rotate to
# invalidate previously-issued pseudonyms.
PRIVACY_SALT=evk-local-dev-salt-rotate-me

# -----------------------------------------------------------------------------
# Delivery pacing + daily quota (Gmail-API-compatible defaults)
# -----------------------------------------------------------------------------
# Enforced by evk.ratelimit. When DELIVERY_DAILY_QUOTA is exceeded the current
# batch aborts and un-sent drafts stay APPROVED for the next run to pick up.
DELIVERY_BATCH_SIZE=45          # max recipients per send batch (hard cap 45)
DELIVERY_DELAY_SECONDS=0.2      # sleep between successive sends
DELIVERY_DAILY_QUOTA=2000       # soft per-process daily cap

# -----------------------------------------------------------------------------
# Thresholds
# -----------------------------------------------------------------------------
# Classifier results below CLASSIFIER_MIN_CONFIDENCE are held back from
# personalisation and the digest; DEDUP_DEADLINE_WINDOW_DAYS is the (type,
# deadline ± N days) pre-filter window used before the Jaccard similarity check.
CLASSIFIER_MIN_CONFIDENCE=0.75
DEDUP_DEADLINE_WINDOW_DAYS=30

# -----------------------------------------------------------------------------
# Scheduler (auto-poll)
# -----------------------------------------------------------------------------
# When AUTO_POLL=true, the server starts a background thread that polls Gmail
# automatically every POLL_INTERVAL_MINUTES. Leave false for manual evk poll.
AUTO_POLL=false
POLL_INTERVAL_MINUTES=30
